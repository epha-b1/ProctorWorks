{
  "name": "proctorworks",
  "version": "1.0.0",
  "description": "ProctorWorks Offline Operations Platform",
  "main": "dist/main.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/src/main",
    "start:dev": "npx ts-node src/main.ts",
    "test": "jest --verbose",
    "test:unit": "jest --testPathPatterns=unit_tests --verbose",
    "test:api:preflight": "node scripts/check-test-db.js",
    "test:api": "node scripts/check-test-db.js && jest --testPathPatterns=API_tests --verbose --runInBand",
    "test:all": "node scripts/check-test-db.js && jest --testPathPatterns='unit_tests|API_tests' --verbose --runInBand",
    "test:cov": "node scripts/check-test-db.js && jest --testPathPatterns='unit_tests|API_tests' --verbose --runInBand --coverage",
    "migration:run": "npx ts-node ./node_modules/typeorm/cli.js migration:run -d src/database/typeorm.config.ts",
    "migration:revert": "npx ts-node ./node_modules/typeorm/cli.js migration:revert -d src/database/typeorm.config.ts",
    "migration:generate": "npx ts-node ./node_modules/typeorm/cli.js migration:generate -d src/database/typeorm.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@nestjs/cli": "^11.0.17",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
