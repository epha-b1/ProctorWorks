DATABASE_URL=postgres://proctorworks:proctorworks@db:5432/proctorworks
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# ENCRYPTION_KEY must be EXACTLY 64 hex characters (256-bit AES key).
# Generate a fresh value per environment with: `openssl rand -hex 32`
# The value below is a placeholder for local dev ONLY — replace it
# before using in any shared / staging / production environment. The
# application will fail-fast at startup if ENCRYPTION_KEY is missing
# or malformed (unless NODE_ENV=test, in which case an ephemeral
# per-process key is generated).
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
PORT=3000
BCRYPT_ROUNDS=12
JWT_EXPIRY=8h
LOW_STOCK_THRESHOLD=10
STALENESS_THRESHOLD_HOURS=24
